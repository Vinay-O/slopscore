{
  "name": "slopscore",
  "version": "1.8.0",
  "description": "Scan your codebase for AI slop, get a Slop Score, ship clean. Zero dependencies. 85 detectors (security, performance, code quality, design tells) + a 181-pattern Anti-Slop Protocol for AI coding agents.",
  "bin": {
    "slopscore": "bin/slopscore.js"
  },
  "type": "commonjs",
  "scripts": {
    "test": "node --test",
    "scan": "node bin/slopscore.js scan .",
    "selfcheck": "node bin/slopscore.js scan . --fail-on minor",
    "demo": "node bin/slopscore.js scan examples/slop.tsx"
  },
  "files": [
    "bin/",
    "src/",
    "ANTI_SLOP_PROTOCOL.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-slop",
    "vibe-coding",
    "code-quality",
    "linter",
    "static-analysis",
    "security",
    "ai-generated-code",
    "code-review",
    "claude-code",
    "cursor",
    "slop"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/Vinay-O/slopscore#readme",
  "bugs": {
    "url": "https://github.com/Vinay-O/slopscore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinay-O/slopscore.git"
  },
  "dependencies": {}
}
